# Copy this file to .env and fill in real values. .env is gitignored -
# never commit it.

# --- Host user mapping (avoids root-owned bind-mount files) ---
# Set these to the output of `id -u` / `id -g` on app01.
UID=1000
GID=1000

# --- Pinned image versions (matches StrangeBee's official reference
# deployment as of 2026-07) ---
CASSANDRA_VERSION=4.1.11
ELASTICSEARCH_VERSION=8.19.15
THEHIVE_VERSION=5.7.3

# --- Elasticsearch ---
# Password for the built-in "elastic" user. Generate with e.g.:
#   tr -dc 'A-Za-z0-9' </dev/urandom | head -c 64
ELASTICSEARCH_PASSWORD=REPLACE_WITH_RANDOM_64_CHAR_STRING

# --- TheHive ---
# Play framework application secret. Generate with e.g.:
#   tr -dc 'A-Za-z0-9' </dev/urandom | head -c 64
THEHIVE_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING

# --- app02 (Cortex + MISP) ---
# API keys generated in Cortex (Organization -> Users -> your TheHive
# service user -> API key) and MISP (My Profile -> Auth keys) - see
# app02/README.md's first-login steps.
CORTEX_API_KEY=REPLACE_WITH_CORTEX_API_KEY
MISP_API_KEY=REPLACE_WITH_MISP_API_KEY
