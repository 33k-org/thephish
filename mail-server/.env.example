# Copy this file to .env and fill in real values. .env is gitignored -
# never commit it.

# --- Pinned image versions ---
MAILSERVER_VERSION=15.1.0

# --- Mail domain/mailbox ---
# FQDN of this mail server. For LAN-only testing this doesn't need to
# resolve anywhere real yet - only needs a DNS MX record once this is
# actually internet-facing.
MAIL_HOSTNAME=REPLACE_WITH_MAIL_HOSTNAME
# The single mailbox used both to receive forwarded emails (IMAP, polled by
# ThePhish-NG) and to send verdict replies from (Cortex's Mailer responder
# authenticates as this account too - see app02/README.md).
MAILBOX_ADDRESS=REPLACE_WITH_MAILBOX_ADDRESS
MAILBOX_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD

# --- ThePhish-NG ---
# Links shown in ThePhish-NG's navbar - just UI links, not used for API
# calls (see THEHIVE_API_URL/CORTEX_API_URL below for those).
THEHIVE_WEB_URL=https://REPLACE_WITH_APP01_HOST:9000
CORTEX_WEB_URL=http://REPLACE_WITH_APP02_HOST:9001
MISP_WEB_URL=https://REPLACE_WITH_APP02_HOST:9443

# TheHive API - the URL ThePhish-NG actually calls to create cases/tasks.
THEHIVE_API_URL=http://REPLACE_WITH_APP01_HOST:9000
THEHIVE_API_KEY=REPLACE_WITH_THEHIVE_API_KEY
THEHIVE_TLS_INSECURE=no

# Cortex API - the URL ThePhish-NG calls to run analyzers.
CORTEX_API_URL=http://REPLACE_WITH_APP02_HOST:9001
CORTEX_API_KEY=REPLACE_WITH_CORTEX_API_KEY
CORTEX_TLS_INSECURE=no

# Name of the MISP instance as configured in TheHive's Cortex/MISP
# connector (Platform management -> Connectors) - not a URL.
MISP_ID=MISP THP

# Default TLP/PAP for cases ThePhish-NG creates (0=white/clear .. 3=red).
CASE_TLP=2
CASE_PAP=2
