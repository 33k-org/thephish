# Secrets - never commit real .env files, only .env.example
.env
**/.env
*.env
!.env.example
!**/.env.example

# Claude Code local project settings
.claude/

# Docker bind-mount data/log directories (created at runtime on the host)
**/data/
**/logs/
**/certs/

# app02 (Cortex + MISP) bind-mount dirs not covered by the generic
# data/logs/certs patterns above
app02/cortex/jobs/
app02/misp/configs/
app02/misp/files/
app02/misp/ssl/
app02/misp/gnupg/
app02/misp/db-data/
app02/misp/redis-data/

# mail-server bind-mount dir - mail data, dovecot state, and the account
# file with password hashes (postfix-accounts.cf) all live here
mail-server/mailserver/

# OS / editor cruft
.DS_Store
*.swp
