# Copy this file to .env and fill in real values. .env is gitignored -
# never commit it.

# --- Host user mapping (avoids root-owned bind-mount files) ---
# Set these to the output of `id -u` / `id -g` on app02.
UID=1000
GID=1000

# GID of the host's `docker` group: `getent group docker | cut -d: -f3`.
# Cortex's entrypoint re-chowns the host's /var/run/docker.sock to match
# this GID on every start (see docker-compose.yml's cortex service comment)
# - get this wrong (or leave it unset) and every Cortex restart locks any
# non-root host user out of their own `docker` CLI.
DOCKER_GID=REPLACE_WITH_HOST_DOCKER_GROUP_GID

# --- Pinned image versions ---
ELASTICSEARCH_VERSION=8.19.15
CORTEX_VERSION=4.1.0
MARIADB_VERSION=10.11
VALKEY_VERSION=7.2
MISP_CORE_VERSION=v2.5.44
MISP_MODULES_VERSION=v3.0.9

# --- Cortex ---
# Absolute host path to this repo's app02/cortex/jobs/ directory (NOT a
# relative path). Cortex's "docker" job runner asks the host's Docker
# daemon to bind-mount this same directory into each analyzer/responder
# container it spawns as a sibling - the daemon resolves that path from the
# host's filesystem, not from inside Cortex's own container, so it has to
# be the real absolute path on app02's disk.
# Example: /home/youruser/thephish/app02/cortex/jobs
CORTEX_JOBS_DIR=REPLACE_WITH_ABSOLUTE_HOST_PATH_TO_APP02_CORTEX_JOBS_DIR

# Play framework application secret. Generate with e.g.:
#   tr -dc 'A-Za-z0-9' </dev/urandom | head -c 64
CORTEX_SECRET_KEY=REPLACE_WITH_RANDOM_64_CHAR_STRING

# Password for Cortex's own Elasticsearch "elastic" user. Generate with e.g.:
#   tr -dc 'A-Za-z0-9' </dev/urandom | head -c 64
CORTEX_ELASTICSEARCH_PASSWORD=REPLACE_WITH_RANDOM_64_CHAR_STRING

# --- Stock Cortex analyzers (free-tier accounts) ---
# Leave blank to skip enabling that analyzer. See README for signup links.
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
URLHAUS_API_KEY=
URLSCAN_API_KEY=

# --- MISP ---
# Reachable address for MISP itself - used both as the BASE_URL MISP
# reports to itself and to size its self-signed cert's CN. Update once
# app02's real LAN hostname/IP is known.
MISP_BASE_URL=https://misp-core

MISP_DB_PASSWORD=REPLACE_WITH_RANDOM_64_CHAR_STRING
MISP_DB_ROOT_PASSWORD=REPLACE_WITH_RANDOM_64_CHAR_STRING
MISP_REDIS_PASSWORD=REPLACE_WITH_RANDOM_64_CHAR_STRING

MISP_ADMIN_EMAIL=admin@thephish.local
MISP_ADMIN_ORG=ThePhish
MISP_ADMIN_PASSWORD=REPLACE_WITH_RANDOM_PASSWORD
MISP_GPG_PASSPHRASE=REPLACE_WITH_RANDOM_PASSPHRASE
# Leave blank to auto-generate on first boot (recommended) - printed once to
# misp-core's container logs on first start:
#   docker compose logs misp-core | grep -A2 -i 'admin key'
MISP_ADMIN_KEY=

# --- ollama-analyzer (not yet built) ---
# GPU box's Ollama endpoint, reachable from app02 only (see top-level
# README's network table - the GPU box firewalls 11434 to app02 alone).
# Placeholder for now; gets wired into Cortex's analyzer config
# (app02/cortex/conf/application.conf) once ollama-analyzer/ exists.
OLLAMA_HOST=REPLACE_WITH_GPU_BOX_HOSTNAME_OR_IP
OLLAMA_PORT=11434

# --- app01 (TheHive) - fill in once app02 is confirmed working ---
# Used to configure TheHive's cortex/misp connector blocks back in
# app01/thehive/conf/application.conf (see its TODO(app02) markers).
# CORTEX_API_KEY=
# MISP_API_KEY=
